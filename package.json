{
  "name": "bibine",
  "productName": "Bibine - Planning Manager",
  "version": "2.1.1",
  "description": "Bibine - Planning Manager — Logiciel de gestion planning",
  "main": "main.js",
  "author": "Amaury Ollivier",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bibine.app",
    "productName": "Bibine - Planning Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "BIBINE-portable.exe"
    }
  }
}
